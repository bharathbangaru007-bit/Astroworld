rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'birthDate', 'birthTime', 'birthPlace', 'location', 'preferences', 'updatedAt']);

      function isValidUser(data) {
        return data.birthDate is string && data.birthDate.size() <= 20
          && data.birthTime is string && data.birthTime.size() <= 10
          && data.birthPlace is string && data.birthPlace.size() <= 200;
      }
    }

    // Readings Subcollection
    match /users/{userId}/readings/{readingId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidReading(incoming())
        && incoming().createdAt == request.time;
      allow delete: if isOwner(userId);

      function isValidReading(data) {
        return data.type in ['daily', 'life_timeline', 'remedy_analysis']
          && data.userId == request.auth.uid;
      }
    }
  }
}
